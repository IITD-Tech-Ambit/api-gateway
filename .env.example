# api-gateway — environment config

PORT=8080
HOST=0.0.0.0
LOG_LEVEL=info
# NODE_ENV=development is set by npm run dev; production Docker sets NODE_ENV=production

# Upstream HTTP services.
#   AUTH_SERVICE_URL / CHATBOT_URL — still proxied over HTTP by the gateway.
#   BACKEND_URL / SEARCH_API_URL   — used ONLY for the informational /health
#     aggregate probe now; /api and /search business traffic goes over gRPC.
AUTH_SERVICE_URL=http://auth-service:4000
BACKEND_URL=http://backend:3002
SEARCH_API_URL=http://search-api:3001
CHATBOT_URL=http://chatbot:3003

# East-west gRPC front door. ALL /api/* (except /api/auth) and /search/* are
# served by calling directory.v1 / search.v1 through Envoy, which demuxes by
# service name (directory.v1.* -> backend:50055, search.v1.* -> search-api:50053).
# auth.v1.VerifyToken (chat session) also goes through here.
ENVOY_GRPC_TARGET=envoy:10000
AUTH_VERIFY_TIMEOUT_MS=3000

# Per-call gRPC deadlines (ms). Sit just above Envoy's route timeouts.
GRPC_DIRECTORY_DEADLINE_MS=30000
GRPC_SEARCH_DEADLINE_MS=30000
GRPC_ATLAS_DEADLINE_MS=120000

# Session cookie issued by auth-service (names must match)
SESSION_COOKIE_NAME=ra_session

# Auth master switch. Secure-by-default: unset/true = session enforced.
# Set to false ONLY for local testing — protected routes then run as a mock dev
# user without IITD OAuth. MUST remain true/unset in production.
ENABLE_AUTH=true

# Local Vite → gateway only; leave empty/unset in production (CORS off)
# CORS_ORIGIN=http://localhost:5173

# protos/ location (set by the Dockerfile; override for local dev if needed)
# PROTO_DIR=/app/protos
